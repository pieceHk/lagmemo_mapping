    "version": "0.2.0",
    "configurations": [

        {
            "name": "Python Debugger: Current File with Arguments",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": "${command:pickArgs}"
        },
        {
            "name": "Python: splatam_i.py",
            "type": "python",
            "request": "launch",
            "program": "/home/sfs/SplaTAM/scripts/splatam_i.py",
            "cwd": "/home/sfs/SplaTAM/",
            "env": {
                "PYTHONPATH": "/home/sfs/SplaTAM/"
            },
            "args": [
                "configs/lagmemo/splatam_0110.py"
            ],
            "pythonArgs": [
            ],
            "justMyCode": false
        },
    ]
}